# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=kairos
POSTGRES_USER=kairos
POSTGRES_PASSWORD=kairos_secret
POSTGRES_PORT=5432

# JDBC URL (Spring Boot / Quarkus)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/kairos
SPRING_DATASOURCE_USERNAME=kairos
SPRING_DATASOURCE_PASSWORD=kairos_secret

# ─── Neo4j ────────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=kairos_secret
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Neo4j driver (Spring Boot)
SPRING_NEO4J_URI=bolt://localhost:7687
SPRING_NEO4J_AUTHENTICATION_USERNAME=neo4j
SPRING_NEO4J_AUTHENTICATION_PASSWORD=kairos_secret
